<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>
  <link rel="stylesheet" href="{{ 'styles.css' | asset_url }}">
  <style>
    .password-page {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #f4d6d8, #faf8f5);
    }
    
    .password-content {
      text-align: center;
      background: white;
      padding: 3rem;
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
      max-width: 500px;
    }
    
    .password-content h1 {
      font-family: 'Georgia', serif;
      color: #5c4033;
      margin-bottom: 1rem;
    }
    
    .password-content form {
      margin-top: 2rem;
    }
    
    .password-content input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #e8e3df;
      border-radius: 4px;
      font-size: 1rem;
      margin-bottom: 1rem;
    }
    
    .password-content button {
      width: 100%;
      background-color: #c9944a;
      color: white;
      padding: 0.75rem;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
    }
    
    .password-content button:hover {
      background-color: #5c4033;
    }
  </style>
</head>
<body>
  <div class="password-page">
    <div class="password-content">
      <h1>{{ shop.name }}</h1>
      <p>Coming Soon</p>
      {{ content_for_layout }}
    </div>
  </div>
</body>
</html>
