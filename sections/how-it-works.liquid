<section class="how-it-works">
  <h2>{{ section.settings.title }}</h2>
  
  <div class="steps-grid">
    {% for step in section.blocks %}
      <div class="step">
        <div class="step-number">{{ forloop.index }}</div>
        <h3>{{ step.settings.step_title }}</h3>
        <p>{{ step.settings.step_description }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .how-it-works {
    background-color: #f4d6d8;
    padding: 4rem 2rem;
    margin: 4rem 0;
  }
  
  .how-it-works h2 {
    font-family: 'Georgia', serif;
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .step {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    text-align: center;
  }
  
  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background-color: #c9944a;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
  }
  
  .step h3 {
    margin-bottom: 0.5rem;
    color: #5c4033;
  }
  
  .step p {
    color: #666666;
  }
</style>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "How It Works"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description"
        }
      ]
    }
  ]
}
{% endschema %}
